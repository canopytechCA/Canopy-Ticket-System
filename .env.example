# Copy this to .env and fill in values — never commit .env to git

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=support.canopytech.ca
CSRF_TRUSTED_ORIGINS=https://support.canopytech.ca
# Change this from the default 'admin/' to reduce attack surface
ADMIN_URL=admin/

# Database
DB_NAME=canopy_tickets
DB_USER=canopy
DB_PASSWORD=change-me-strong-password
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Email — Office 365 via Microsoft Graph API
# App registration needs Mail.Send application permission (not delegated)
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=
SUPPORT_EMAIL=support@canopytechresources.ca
# Public URL used in email links (no trailing slash)
SITE_URL=https://support.canopytech.ca

# Azure AD SSO (Phase 2)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# Service-to-service API key (used by Chat Agent to create tickets)
# Generate a strong random string: python -c "import secrets; print(secrets.token_hex(32))"
CANOPY_API_KEY=
